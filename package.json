{
  "name": "web-page-enhancement-scripts",
  "version": "2.5.13",
  "packageManager": "bun@1.3.8",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-all.mjs",
    "dev": "vite",
    "dev:chatgpt-notify": "vite --mode chatgpt-notify",
    "dev:d-anime": "vite --mode d-anime",
    "dev:d-anime-cf-ranking": "vite --mode d-anime-cf-ranking",
    "dev:fanbox-floating-menu": "vite --mode fanbox-floating-menu",
    "dev:fanbox-pagination-helper": "vite --mode fanbox-pagination-helper",
    "dev:hf-download-command-copier": "vite --mode hf-download-command-copier",
    "dev:image-collector": "vite --mode image-collector",
    "dev:imgur-direct-link-copier": "vite --mode imgur-direct-link-copier",
    "dev:khinsider-direct-link-saver": "vite --mode khinsider-direct-link-saver",
    "dev:manga-viewer": "vite --mode manga-viewer",
    "dev:native-video-volume-setter": "vite --mode native-video-volume-setter",
    "dev:trickcal-tool-sweep": "vite --mode trickcal-tool-sweep",
    "dev:twitter-clean-timeline": "vite --mode twitter-clean-timeline",
    "dev:twitter-clean-ui": "vite --mode twitter-clean-ui",
    "dev:twitter-full-size-image": "vite --mode twitter-full-size-image",
    "dev:twitter-thread-copier": "vite --mode twitter-thread-copier",
    "dev:x-auto-spam-reporter": "vite --mode x-auto-spam-reporter",
    "dev:x-community-note-close": "vite --mode x-community-note-close",
    "dev:yahoo-mail-ad-cleaner": "vite --mode yahoo-mail-ad-cleaner",
    "dev:yahoo-mail-mark-read": "vite --mode yahoo-mail-mark-read",
    "dev:youtube-info-copier": "vite --mode youtube-info-copier",
    "dev:youtube-ui-modifier": "vite --mode youtube-ui-modifier",
    "format": "prettier --write src/**/*.ts",
    "lint": "eslint src/**/*.ts",
    "preview": "vite preview",
    "test": "node scripts/nicomanga-image-collection-regression.mjs",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "userscript",
    "tampermonkey",
    "greasemonkey",
    "violetmonkey",
    "vite",
    "typescript"
  ],
  "license": "MIT",
  "overrides": {
    "brace-expansion": "1.1.13",
    "flatted": "3.4.2",
    "minimatch": "3.1.4",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/greasemonkey": "^4.0.7",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/tampermonkey": "^5.0.5",
    "eslint": "^10.6.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "react-refresh": "^0.18.0",
    "systemjs": "^6.15.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-plugin-monkey": "^8.0.6",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@mdi/js": "7.4.47",
    "comment-overlay": "^4.0.0",
    "fflate": "^0.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
